# 复制为 .env 并填入真实值；.env 不入库，也不进镜像（compose 用 env_file 注入）

# Mumble 服务器密码（如有）
MUMBLE_PASSWORD=

# OpenRouter（主 LLM，路由 DeepSeek V4 到 Western provider）
OPENROUTER_API_KEY=

# 阿里云 DashScope（paraformer 实时 STT）
DASHSCOPE_API_KEY=

# Fish Audio（s2-pro TTS）
FISH_API_KEY=

# DeepSeek（主 LLM，OpenAI 兼容）
DEEPSEEK_API_KEY=

# Google Gemini（兜底 LLM）
GEMINI_API_KEY=
